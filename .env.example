# ── LOCAL (Docker) ─────────────────────────────────────────────────────────────
POSTGRES_USER=aestheva
POSTGRES_PASSWORD=cambia_esto
POSTGRES_DB=aestheva_db
DATABASE_URL=postgresql+asyncpg://aestheva:cambia_esto@db:5432/aestheva_db

# ── PRODUCCIÓN (Supabase) ──────────────────────────────────────────────────────
# Copia el "Connection string" de: Supabase → Settings → Database → URI
# DATABASE_URL=postgresql://postgres:[PASSWORD]@db.[REF].supabase.co:5432/postgres

# ── SEGURIDAD ──────────────────────────────────────────────────────────────────
# Genera con: python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=genera_un_secreto_largo_aqui_minimo_32_chars
CLINIC_SECRET=secreto_para_tokens_de_marketing_minimo_32_chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=480

# ── ENTORNO ────────────────────────────────────────────────────────────────────
ENVIRONMENT=development

# ── CORS — OBLIGATORIO EN PRODUCCIÓN ──────────────────────────────────────────
# Sin esta variable el backend solo acepta peticiones desde localhost.
# Pon aquí el dominio exacto de Vercel (sin barra final).
# En Railway: Settings → Variables → Add Variable
ALLOWED_ORIGINS=https://tu-proyecto.vercel.app

# ── FRONTEND (Vercel) ──────────────────────────────────────────────────────────
# En Vercel: Settings → Environment Variables → Add
# VITE_API_URL=https://tu-backend.railway.app
